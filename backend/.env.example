# =============================================================================
# Assistente Social Media — Backend
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Conexão asyncpg do backend (role mkt_app, sem BYPASSRLS — RLS aplica)
SUPABASE_DB_URL=postgresql://mkt_app:<senha>@<host>:5432/postgres

# Conexão admin (role postgres) — usada APENAS pelo run_migrations.py
SUPABASE_DB_URL_ADMIN=postgresql://postgres:<senha>@<host>:5432/postgres

# Senha do role mkt_app (criada na migração 000a, injetada via :mkt_app_password)
MKT_APP_DB_PASSWORD=

# --- Auth ---
# true em dev (injeta DEV_USER_ID/DEV_TENANT_ID), false em produção (valida JWT Supabase)
AUTH_BYPASS=true
DEV_TENANT_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ID=00000000-0000-0000-0000-000000000002

# --- App ---
APP_ENV=development
APP_PORT=3002
FRONTEND_URL=http://localhost:5173

# --- Models ---
ANTHROPIC_MODEL_ORCHESTRATOR=claude-sonnet-4-6
ANTHROPIC_MODEL_CONTENT=claude-sonnet-4-6
ANTHROPIC_MODEL_BRAND=claude-haiku-4-5-20251001

# Verifique ID atual em https://ai.google.dev/gemini-api/docs/models — muda com frequência
GEMINI_MODEL_IMAGE=gemini-3.1-flash-image-preview
