# Banco MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=db_meu_projeto

# Auth
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_EXPIRE_HOURS=720

# LLM
ANTHROPIC_API_KEY=

# WhatsApp (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Scheduler
SCHEDULER_ENABLED=true

# OCR
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=por

# Uploads
UPLOAD_DIR=/tmp/uploads

# Selenium / Automação web
HEADLESS=true
TIMEOUT_PAGINA=20
TIMEOUT_ELEMENTO=10
DELAY_MIN=1.0
DELAY_MAX=3.0
