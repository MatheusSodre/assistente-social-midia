# /etc/nginx/sites-available/socialmedia.orbitaia.com.br
# Frontend estático + reverse proxy pro backend FastAPI :3002.

server {
    listen 80;
    listen [::]:80;
    server_name socialmedia.orbitaia.com.br;

    # Redireciona pra HTTPS após certbot configurar
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name socialmedia.orbitaia.com.br;

    ssl_certificate     /etc/letsencrypt/live/socialmedia.orbitaia.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/socialmedia.orbitaia.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Frontend estático (vite build)
    root /opt/assistente-social-media-frontend/dist;
    index index.html;

    # SPA: rota desconhecida → index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API + assets backend
    location /api/ {
        proxy_pass         http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
    }

    # SSE: desabilitar buffering pra eventos chegarem em tempo real
    location ~ ^/api/v1/generations/[0-9a-f-]+/stream$ {
        proxy_pass            http://127.0.0.1:3002;
        proxy_http_version    1.1;
        proxy_set_header      Host              $host;
        proxy_set_header      X-Real-IP         $remote_addr;
        proxy_set_header      Connection        "";
        proxy_buffering       off;
        proxy_cache           off;
        proxy_read_timeout    1h;
        proxy_send_timeout    1h;
        chunked_transfer_encoding on;
    }

    # /health pro Nginx ou load balancer
    location = /health {
        proxy_pass http://127.0.0.1:3002/health;
    }

    # Limites e gzip básicos
    client_max_body_size 20M;
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;
}
